# Database Configuration
DATABASE_URL="file:./data.db"

# Session Secret - Generate a strong secret for production
SESSION_SECRET="your-super-secret-session-key-here"

# Application Environment
NODE_ENV="production"

# Optional: Application URL for SEO and social sharing
APP_URL="https://your-optical-shop-domain.com"

# SEO Environment Variables
# Google Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Search Console
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your-verification-code-here

# Site Configuration
SITE_URL=https://yourdomain.com
SITE_NAME="Your Optical Shop"
SITE_DESCRIPTION="Premium eyewear collection with personalized service"

# Business Information
BUSINESS_PHONE="+1-800-OPTICAL"
BUSINESS_EMAIL="hello@yourdomain.com"
BUSINESS_WHATSAPP="+1-800-OPTICAL"

# Address
BUSINESS_STREET="123 Vision Street"
BUSINESS_CITY="Eye City"
BUSINESS_STATE="NY"
BUSINESS_ZIP="10001"
BUSINESS_COUNTRY="United States"

# Coordinates (for local SEO)
BUSINESS_LATITUDE="40.7128"
BUSINESS_LONGITUDE="-74.0060"

# Social Media
FACEBOOK_URL="https://facebook.com/yourshop"
INSTAGRAM_URL="https://instagram.com/yourshop"
TWITTER_URL="https://twitter.com/yourshop"

# SEO Settings
DEFAULT_IMAGE="/logo-light.png"
FAVICON="/favicon.ico"

# Optional: Contact Information
BUSINESS_NAME="Optical Shop"
BUSINESS_EMAIL="info@opticalshop.com"
BUSINESS_PHONE="+1234567890"
BUSINESS_ADDRESS="123 Main Street, City, State 12345"

# Optional: Analytics
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# Optional: File Upload Configuration
MAX_FILE_SIZE="5242880" # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"
