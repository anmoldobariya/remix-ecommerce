# Database Configuration
DATABASE_URL="file:./data.db"

# Session Secret - Generate a strong secret for production
SESSION_SECRET="your-super-secret-session-key-here"

# JWT Secret - Generate a strong secret for JWT tokens
JWT_SECRET="your-jwt-secret-here-please-change-in-production"

# Application Environment
NODE_ENV="production"

# Analytics & SEO (Optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your-verification-code-here

# File Upload Configuration
MAX_FILE_SIZE="5242880" # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
